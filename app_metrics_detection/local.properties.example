# ============================================================
# LOCAL PROPERTIES - EXAMPLE TEMPLATE
# ============================================================
# Copy this file as local.properties only if Android Studio does not
# generate it automatically when opening the project.
#
# local.properties is ignored and must not be uploaded.
# ============================================================

# Linux:
# sdk.dir=/home/USER/Android/Sdk
#
# Windows (escapar barras invertidas):
# sdk.dir=C\:\\Users\\USER\\AppData\\Local\\Android\\Sdk
#
# macOS:
# sdk.dir=/Users/USER/Library/Android/sdk
