<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="NotificationPermission">

    <!-- Network permissions: required for backend sync and connectivity detection -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Camera permission: required to capture bunch images -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <!-- Legacy permissions: kept only for compatibility with older Android versions -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!--
        Main application configuration.

        Improvements applied:
        - allowBackup=false:
          prevents automatic backup of local database, images, preferences, and credentials.
        - networkSecurityConfig:
          uses network policy defined in res/xml/network_security_config.xml.
        - dataExtractionRules/fullBackupContent removed:
          no longer needed because allowBackup is disabled.

        Legacy notes:
        - READ_EXTERNAL_STORAGE kept for compatibility (maxSdk=32).
        - WRITE_EXTERNAL_STORAGE removed: camera uses FileProvider + cache, gallery uses GetContent.
    -->
    <application
        android:name=".MetricsDetectionApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.YOLOv8InstanceSegmentation"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">

        <!--
            FileProvider:
            allows controlled sharing of internal files with camera,
            PDF viewer, or other authorized components.

            Security:
            - exported=false prevents direct external exposure.
            - grantUriPermissions=true allows granting temporary per-URI permissions.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">

            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Main app launcher -->
        <activity
            android:name=".LauncherActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- Authentication flow -->
        <activity android:name=".auth.LoginActivity" />
        <activity android:name=".auth.RegisterActivity" />
        <activity android:name=".auth.RecoveryActivity" />

        <!-- Main activity -->
        <activity android:name=".MainActivity" />

        <!--
            Debug/batch activity.

            Kept for compatibility with internal/forensic tools,
            but protected with exported=false to prevent opening from other apps.

            Do not remove without reviewing:
            - BatchProcessor
            - internal test flows
            - report generation or batch processing
        -->
        <activity
            android:name=".DebugBatchActivity"
            android:excludeFromRecents="true"
            android:exported="false" />

    </application>

</manifest>
