<!-- res/layout/fragment_lote_detail.xml -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/detailContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:paddingHorizontal="16dp">

    <!-- ─── Toolbar con back + título + share ───────────────────────── -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarDetail"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:backgroundTint="@color/surface"
        app:contentInsetStartWithNavigation="0dp"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="Detalle de Lote"
        app:titleCentered="true"
        app:menu="@menu/menu_share"
        app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6"
        app:popupTheme="@style/ThemeOverlay.MaterialComponents.Light"/>


    <!-- ─── Card con detalles de lote ───────────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDetail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/toolbarDetail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="12dp"
        android:backgroundTint="@android:color/transparent"
        app:strokeColor="@color/outlineGray"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Primera fila: ID + datos + estado nube -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Datos principales -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvLoteId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="N°123456"
                        android:textColor="@android:color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCompany"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Empresa XYZ"
                        android:textColor="@color/textSecondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvVessel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Embarcación 1"
                        android:textColor="@color/textSecondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvBlock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Bloque A"
                        android:textColor="@color/textSecondary"
                        android:textSize="14sp" />


                </LinearLayout>

                <!-- Estado en nube -->
                <ImageView
                    android:id="@+id/ivCloudStatus"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_cloud"
                    app:tint="@color/textSecondary" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="@color/outlineGray" />

            <!-- Segunda fila: hora + fecha -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_clock"
                    app:tint="@color/textSecondary" />

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="09:00 AM"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp" />

                <Space android:layout_width="16dp" android:layout_height="wrap_content" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/textSecondary" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="26 Abril 2025"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp" />

                <Space android:layout_width="16dp" android:layout_height="wrap_content" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_image"
                    app:tint="@color/textSecondary" />

                <TextView
                    android:id="@+id/tvImagesLen"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:text="5 Img"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- RecyclerView de imágenes/predicciones: ocupa todo el espacio restante -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerDetail"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardDetail"
        app:layout_constraintBottom_toTopOf="@id/btnDeleteLote"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:nestedScrollingEnabled="false" />

    <!-- Botón Eliminar Lote fijado al fondo -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDeleteLote"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Eliminar Lote"
        android:textColor="@color/dark_red"
        app:strokeColor="@color/dark_red"
        app:strokeWidth="2dp"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
