# ============================================================
# KEYSTORE PROPERTIES — TEMPLATE DE EJEMPLO
# ============================================================
# 1. Copia este archivo como keystore.properties (sin .example)
# 2. Reemplaza los valores con tus credenciales reales
# 3. Asegúrate de que la ruta storeFile apunte al archivo .jks
# 4. keystore.properties está en .gitignore — NO se sube al repo
# ============================================================

storeFile=/ABSOLUTE/PATH/TO/your-release-key.jks
storePassword=CHANGE_ME
keyAlias=CHANGE_ME
keyPassword=CHANGE_ME
