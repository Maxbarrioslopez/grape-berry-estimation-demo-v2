# ============================================================
# KEYSTORE PROPERTIES - EXAMPLE TEMPLATE
# ============================================================
# 1. Copy this file as keystore.properties (without .example).
# 2. Replace these values with your private signing credentials.
# 3. Make sure storeFile points to your .jks file.
# 4. keystore.properties is ignored and must not be uploaded.
# ============================================================

storeFile=/ABSOLUTE/PATH/TO/your-release-key.jks
storePassword=CHANGE_ME
keyAlias=CHANGE_ME
keyPassword=CHANGE_ME
